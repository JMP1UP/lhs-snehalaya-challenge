rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public splash screen should only use non-identifying aggregate data.
    match /publicStats/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User profiles should only be read/written by the signed-in user.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Temporary authenticated access model.
    // Tighten staff dashboard access further before full launch.
    match /entries/{entryId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
  }
}
